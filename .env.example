# ============================================================
# HyperAgents environment template / HyperAgents 环境变量模板
#
# EN: Copy this file to .env in the workspace root before running.
# ZH: 运行前请将本文件复制为工作区根目录下的 .env。
# ============================================================

# =========================
# App basics / 应用基础配置
# =========================
# EN: Service metadata.
# ZH: 服务元信息。
APP_NAME=HyperAgents API
APP_VERSION=0.1.0

# =========================
# Database / 数据库配置
# =========================
# EN: PostgreSQL DSN used by API and Alembic migrations.
# ZH: API 与 Alembic 迁移共用的 PostgreSQL 连接串。
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/hyperagents

# EN: Auto-create tables at startup (dev only). true/false.
# ZH: 启动时自动建表（仅开发环境建议开启）。true/false。
AUTO_CREATE_TABLES=false

# EN: Allowed CORS origins, comma separated.
# ZH: 允许的跨域来源，使用英文逗号分隔。
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# =========================
# LLM provider / 大模型 Provider 配置
# =========================
# EN: OpenAI credentials and defaults.
# ZH: OpenAI 凭证与默认模型。
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_DEFAULT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# EN: Local provider endpoint (Ollama/vLLM compatible OpenAI API).
# ZH: 本地模型服务地址（兼容 OpenAI API，例如 Ollama/vLLM）。
LOCALHOST_LLM_BASE_URL=http://localhost:11434/v1
LOCALHOST_DEFAULT_MODEL=qwen2.5:7b
LOCALHOST_EMBEDDING_MODEL=nomic-embed-text

# EN: Runtime default chat provider when no provider specified by agent.
# ZH: 当 Agent 未指定 provider 时，Runtime 使用的默认 provider。
RUNTIME_DEFAULT_PROVIDER=localhost

# EN: Embedding provider used by memory service.
# ZH: Memory 服务默认使用的向量 provider。
EMBEDDING_PROVIDER=openai

# EN: Outbound request timeout for provider/embedding HTTP calls.
# ZH: 调用外部模型/向量服务时的 HTTP 超时（秒）。
MODEL_REQUEST_TIMEOUT_SECONDS=60

# =========================
# Memory service / 记忆服务配置
# =========================
# EN: Embedding vector dimension and retry policy.
# ZH: 向量维度与失败重试策略。
MEMORY_EMBEDDING_DIMENSIONS=1536
EMBEDDING_RETRY_MAX_ATTEMPTS=3
EMBEDDING_RETRY_BACKOFF_SECONDS=30

# =========================
# Frontend / 前端配置
# =========================
# EN: Frontend API base URL (used by Vite app).
# ZH: 前端调用后端 API 的基础地址（Vite 应用使用）。
VITE_API_BASE_URL=http://localhost:8000
